# DeepSeek API Key（用于中文→英文翻译，OpenAI 兼容接口）
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ElevenLabs API Key（用于英文文本→语音合成）
# 从 https://elevenlabs.io/app/settings/api-keys 获取
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# （可选）覆盖默认语音 ID
# ELEVENLABS_VOICE_A_ID=JBFqnCBsd6RMkjVDRZzb
# ELEVENLABS_VOICE_B_ID=TxGEqnHWrfWFTfGW9XjX
